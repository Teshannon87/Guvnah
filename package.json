{
  "name": "guvnah-context",
  "version": "0.1.0",
  "description": "Local-first proxy that inspects what your AI agent is stuffing into the prompt.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "guvnah-context": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "guvnah.context.example.yaml",
    ".env.example",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/cli/index.js', 0o755)\"",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "fastify": "^5.0.0",
    "js-tiktoken": "^1.0.15",
    "nanoid": "^5.0.7",
    "piscina": "^5.1.4",
    "undici": "^6.20.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
